# ==============================================================================
# Agentic AI Framework for Autonomous Retail Fraud Investigation
# Environmental Configuration Template
# ==============================================================================

# Application General Config
APP_NAME="Retail Fraud Investigation API"
APP_ENV=development  # development, staging, production
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=generate_a_secure_long_secret_key_here_for_production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fraud_investigation
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# AI/Agent Configurations (For enterprise LLM routing)
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-1.5-pro
LLM_TEMPERATURE=0.0

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json # json, text
